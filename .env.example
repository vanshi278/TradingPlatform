# ===== AlphaForge environment =====
# Copy to .env and fill in.  .env is gitignored; .env.example is committed.
#   cp .env.example .env

# ---- TimescaleDB / Postgres ----
POSTGRES_USER=alphaforge
POSTGRES_PASSWORD=alphaforge
POSTGRES_DB=alphaforge
POSTGRES_PORT=5432
# Host: "timescaledb" when the backend runs inside docker-compose,
#       "localhost" when you run the backend from a local venv.
POSTGRES_HOST=localhost

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# Inside docker-compose use: redis://redis:6379/0

# ---- Auth (Phase 9) ----
# Generate one:  openssl rand -hex 32
JWT_SECRET=change-me
JWT_TTL_HOURS=24

# ---- Trading (Phase 9) ----
# "paper" (default): simulated fills, no real money.
# "live": routes orders to Angel One SmartAPI — requires ALL SMARTAPI_* below,
#         an Angel One demat account, and your registered static IP (their
#         Apr-2026 rule for self-hosted algos). Real money — use deliberately.
TRADING_MODE=paper

# Angel One SmartAPI (free API; normal brokerage applies per executed order).
# Create an app at smartapi.angelbroking.com; enable TOTP and keep its secret.
SMARTAPI_KEY=
SMARTAPI_CLIENT_CODE=
SMARTAPI_PIN=
SMARTAPI_TOTP_SECRET=

# ---- AI (Phase 9) ----
# Free Gemini key from aistudio.google.com — enables LLM market analysis.
# Leave blank to use the built-in rule-based analyst (no external calls).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Legacy broker slots (Phase 1 scaffold, optional) ----
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
